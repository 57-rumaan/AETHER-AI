# Copy this file to ".env" and fill in real values. Never commit ".env" to git.

PORT=3000

# Random long string — used to sign login sessions. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Admin password, stored as a BCRYPT HASH — never plaintext.
# Generate the hash for your chosen password with:
# node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD_HERE', 10))"
ADMIN_PASSWORD_HASH=

# Add one line per AI provider you connect in the admin panel.
OPENAI_API_KEY=
GEMINI_API_KEY=
